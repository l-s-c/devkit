[{"t": "关关雎鸠，在河之洲。窈窕淑女，君子好逑", "a": "诗经·关雎", "d": "先秦", "chars": ["窈", "淑", "雎"], "g": "女"}, {"t": "桃之夭夭，灼灼其华", "a": "诗经·桃夭", "d": "先秦", "chars": ["灼", "华"], "g": "女"}, {"t": "青青子衿，悠悠我心", "a": "诗经·子衿", "d": "先秦", "chars": ["衿", "悠"], "g": "中"}, {"t": "蒹葭苍苍，白露为霜", "a": "诗经·蒹葭", "d": "先秦", "chars": ["霜", "露"], "g": "中"}, {"t": "呦呦鹿鸣，食野之苹", "a": "诗经·鹿鸣", "d": "先秦", "chars": ["鹿", "苹"], "g": "中"}, {"t": "如切如磋，如琢如磨", "a": "诗经·淇奥", "d": "先秦", "chars": ["琢", "磨"], "g": "男"}, {"t": "有匪君子，如金如锡，如圭如璧", "a": "诗经·淇奥", "d": "先秦", "chars": ["璧", "圭"], "g": "男"}, {"t": "静女其姝，俟我于城隅", "a": "诗经·静女", "d": "先秦", "chars": ["静", "姝"], "g": "女"}, {"t": "瞻彼淇奥，绿竹猗猗", "a": "诗经·淇奥", "d": "先秦", "chars": ["竹", "淇"], "g": "中"}, {"t": "言念君子，温其如玉", "a": "诗经·小戎", "d": "先秦", "chars": ["念", "温", "玉"], "g": "中"}, {"t": "路漫漫其修远兮，吾将上下而求索", "a": "楚辞·离骚", "d": "先秦", "chars": ["修", "远"], "g": "男"}, {"t": "纷吾既有此内美兮，又重之以修能", "a": "楚辞·离骚", "d": "先秦", "chars": ["修", "能"], "g": "男"}, {"t": "扈江离与辟芷兮，纫秋兰以为佩", "a": "楚辞·离骚", "d": "先秦", "chars": ["兰", "芷"], "g": "女"}, {"t": "日月忽其不淹兮，春与秋其代序", "a": "楚辞·离骚", "d": "先秦", "chars": ["春", "秋"], "g": "中"}, {"t": "惟草木之零落兮，恐美人之迟暮", "a": "楚辞·离骚", "d": "先秦", "chars": ["暮", "零"], "g": "中"}, {"t": "朝饮木兰之坠露兮，夕餐秋菊之落英", "a": "楚辞·离骚", "d": "先秦", "chars": ["露", "兰", "英"], "g": "中"}, {"t": "沧浪之水清兮，可以濯吾缨", "a": "楚辞·渔父", "d": "先秦", "chars": ["清", "澜", "沧"], "g": "男"}, {"t": "悲莫悲兮生别离，乐莫乐兮新相知", "a": "楚辞·九歌", "d": "先秦", "chars": ["乐", "知"], "g": "中"}, {"t": "海上生明月，天涯共此时", "a": "张九龄·望月怀远", "d": "唐", "chars": ["明", "海"], "g": "男"}, {"t": "大鹏一日同风起，扶摇直上九万里", "a": "李白·上李邕", "d": "唐", "chars": ["鹏", "风"], "g": "男"}, {"t": "长风破浪会有时，直挂云帆济沧海", "a": "李白·行路难", "d": "唐", "chars": ["帆", "海", "云"], "g": "男"}, {"t": "天生我材必有用", "a": "李白·将进酒", "d": "唐", "chars": ["天", "材"], "g": "男"}, {"t": "仰天大笑出门去，我辈岂是蓬蒿人", "a": "李白·南陵别儿童入京", "d": "唐", "chars": ["天", "蒿"], "g": "男"}, {"t": "会当凌绝顶，一览众山小", "a": "杜甫·望岳", "d": "唐", "chars": ["凌", "岳"], "g": "男"}, {"t": "读书破万卷，下笔如有神", "a": "杜甫·奉赠韦左丞丈二十二韵", "d": "唐", "chars": ["书", "卷"], "g": "中"}, {"t": "随风潜入夜，润物细无声", "a": "杜甫·春夜喜雨", "d": "唐", "chars": ["润", "潜"], "g": "中"}, {"t": "千里莺啼绿映红，水村山郭酒旗风", "a": "杜牧·江南春", "d": "唐", "chars": ["莺", "映"], "g": "女"}, {"t": "春风得意马蹄疾，一日看尽长安花", "a": "孟郊·登科后", "d": "唐", "chars": ["春", "花"], "g": "中"}, {"t": "落霞与孤鹜齐飞，秋水共长天一色", "a": "王勃·滕王阁序", "d": "唐", "chars": ["霞", "秋"], "g": "中"}, {"t": "海内存知己，天涯若比邻", "a": "王勃·送杜少府之任蜀州", "d": "唐", "chars": ["知", "海"], "g": "男"}, {"t": "大漠孤烟直，长河落日圆", "a": "王维·使至塞上", "d": "唐", "chars": ["漠", "圆"], "g": "男"}, {"t": "行到水穷处，坐看云起时", "a": "王维·终南别业", "d": "唐", "chars": ["云", "水"], "g": "中"}, {"t": "明月松间照，清泉石上流", "a": "王维·山居秋暝", "d": "唐", "chars": ["清", "泉", "松"], "g": "中"}, {"t": "欲穷千里目，更上一层楼", "a": "王之涣·登鹳雀楼", "d": "唐", "chars": ["千", "楼"], "g": "男"}, {"t": "春蚕到死丝方尽，蜡炬成灰泪始干", "a": "李商隐·无题", "d": "唐", "chars": ["丝", "灰"], "g": "中"}, {"t": "身无彩凤双飞翼，心有灵犀一点通", "a": "李商隐·无题", "d": "唐", "chars": ["灵", "凤", "翼"], "g": "中"}, {"t": "沉舟侧畔千帆过，病树前头万木春", "a": "刘禹锡·酬乐天", "d": "唐", "chars": ["帆", "春"], "g": "男"}, {"t": "旧时王谢堂前燕，飞入寻常百姓家", "a": "刘禹锡·乌衣巷", "d": "唐", "chars": ["燕", "飞"], "g": "女"}, {"t": "不畏浮云遮望眼，自缘身在最高层", "a": "王安石·登飞来峰", "d": "宋", "chars": ["望", "云"], "g": "男"}, {"t": "但愿人长久，千里共婵娟", "a": "苏轼·水调歌头", "d": "宋", "chars": ["婵", "娟"], "g": "女"}, {"t": "大江东去，浪淘尽，千古风流人物", "a": "苏轼·念奴娇", "d": "宋", "chars": ["江", "浪"], "g": "男"}, {"t": "一蓑烟雨任平生", "a": "苏轼·定风波", "d": "宋", "chars": ["任", "平"], "g": "男"}, {"t": "人生如逆旅，我亦是行人", "a": "苏轼·临江仙", "d": "宋", "chars": ["逸", "行"], "g": "男"}, {"t": "疏影横斜水清浅，暗香浮动月黄昏", "a": "林逋·山园小梅", "d": "宋", "chars": ["影", "香"], "g": "女"}, {"t": "知否，知否，应是绿肥红瘦", "a": "李清照·如梦令", "d": "宋", "chars": ["知"], "g": "女"}, {"t": "此情无计可消除，才下眉头，却上心头", "a": "李清照·一剪梅", "d": "宋", "chars": ["心", "念"], "g": "女"}, {"t": "生当作人杰，死亦为鬼雄", "a": "李清照·夏日绝句", "d": "宋", "chars": ["杰", "雄"], "g": "男"}, {"t": "山重水复疑无路，柳暗花明又一村", "a": "陆游·游山西村", "d": "宋", "chars": ["明", "柳"], "g": "中"}, {"t": "零落成泥碾作尘，只有香如故", "a": "陆游·卜算子", "d": "宋", "chars": ["香", "尘"], "g": "女"}, {"t": "青山遮不住，毕竟东流去", "a": "辛弃疾·菩萨蛮", "d": "宋", "chars": ["青", "东"], "g": "男"}, {"t": "众里寻他千百度，蓦然回首，那人却在灯火阑珊处", "a": "辛弃疾·青玉案", "d": "宋", "chars": ["阑", "珊"], "g": "女"}, {"t": "醉里挑灯看剑，梦回吹角连营", "a": "辛弃疾·破阵子", "d": "宋", "chars": ["剑", "梦"], "g": "男"}, {"t": "九万里风鹏正举", "a": "李清照·渔家傲", "d": "宋", "chars": ["鹏", "举"], "g": "男"}, {"t": "山高月小，水落石出", "a": "苏轼·后赤壁赋", "d": "宋", "chars": ["月", "石"], "g": "中"}, {"t": "清风徐来，水波不兴", "a": "苏轼·前赤壁赋", "d": "宋", "chars": ["清", "风", "徐"], "g": "中"}, {"t": "问渠那得清如许，为有源头活水来", "a": "朱熹·观书有感", "d": "宋", "chars": ["清", "源"], "g": "中"}, {"t": "等闲识得东风面，万紫千红总是春", "a": "朱熹·春日", "d": "宋", "chars": ["春", "紫"], "g": "中"}, {"t": "粉身碎骨浑不怕，要留清白在人间", "a": "于谦·石灰吟", "d": "明", "chars": ["清", "白"], "g": "男"}, {"t": "海纳百川，有容乃大", "a": "林则徐", "d": "清", "chars": ["海", "川"], "g": "男"}, {"t": "壁立千仞，无欲则刚", "a": "林则徐", "d": "清", "chars": ["壁", "刚"], "g": "男"}]